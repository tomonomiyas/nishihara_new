{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "extends": ["eslint:recommended", "prettier"],
  "globals": {
    "jQuery": "readonly",
    "Splide": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn"
  }
}
